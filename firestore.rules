rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global rule for pre_registered_salespeople
    match /pre_registered_salespeople/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Global rule for shared_logs (Transfers)
    match /shared_logs/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Global rule for retailer_stocks
    match /retailer_stocks/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Global rule for sales logs
    match /sales_logs/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Global rule for scan logs
    match /scan_logs/{document=**} {
      allow read, write: if request.auth != null;
    }

    // User's root document (contains profile and PIN)
    match /users/{userId} {
      // Anyone logged in anonymously can read to check existence and login
      allow read: if request.auth != null;
      // Can create if it doesn't exist, can update if they own it
      allow write: if request.auth != null && 
        (!exists(/databases/$(database)/documents/users/$(userId)) || 
         get(/databases/$(database)/documents/users/$(userId)).data.uid == request.auth.uid);
    }

    // User's subcollections (products, sales, customers, salespeople)
    match /users/{userId}/{collectionName}/{document=**} {
      // Owner can read/write
      allow read: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(userId)).data.uid == request.auth.uid ||
        collectionName == 'products' || collectionName == 'salespeople'
      );
      allow write: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(userId)).data.uid == request.auth.uid;
    }
  }
}
